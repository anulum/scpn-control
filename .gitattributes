# SPDX-License-Identifier: MIT OR Apache-2.0

# Line ending normalization
* text=auto

# Linguist overrides
*.rs linguist-language=Rust

# Binary files (no diff, no merge)
*.npz binary
*.npy binary
*.onnx binary
*.pt binary
*.pkl binary
*.png binary
*.jpg binary
*.svg binary
*.mp4 binary
*.gif binary
*.h5 binary
*.hdf5 binary

# Lock files -- generated, do not diff
Cargo.lock linguist-generated
